# Keep only placeholder data directories in git; local datasets and split artifacts stay untracked.
data/raw/**
!data/raw/.gitkeep
data/processed/**
!data/processed/.gitkeep
data/splits/**
!data/splits/.gitkeep

## Build and packaging artifacts
build/
dist/
*.egg-info/
pip-wheel-metadata/

## Jupyter and notebook temp files
.ipynb_checkpoints/

## Local environment files
.env
.env.*
.codex/

## Editor / OS clutter
.vscode/
.idea/
.DS_Store

# Keep only compact benchmark summaries in git.
results/*
!results/summaries/
!results/summaries/**
# New timestamped benchmark experiment outputs are local-only.
results/summary/

# Example predictor pickles exceed GitHub's 100MB file limit; regenerate locally.
examples/results/**/*.pkl
